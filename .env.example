# =============================================================================
# Visual Forge 环境变量配置模板
# =============================================================================
# 复制此文件为 .env 并填入你的 API 密钥：
#   cp .env.example .env
#
# 只需配置你想用的引擎密钥，不需要两个都配。
# VF_PROVIDER=auto 时会按 yunwu → grsai 顺序尝试。
# =============================================================================


# ===== 主引擎（yunwu / Gemini）=====
# yunwu.ai 的 API Key，兼容 OpenAI 接口格式
# 注册地址：https://yunwu.ai/register?aff=ml8W
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://yunwu.ai/v1

# ===== 备用引擎（grsai / nano-banana / gpt-image）=====
# grsai nano-banana 生图引擎（用于 fallback）
# 注册地址：海外 https://grsai.com/zh / 国内直连 https://grsai.ai/zh
BANANA_API_URL=http://grsai.dakka.com.cn/v1/draw/nano-banana
BANANA_API_KEY=sk-your-api-key-here

# grsai gpt-image 引擎（与 nano-banana 共用 key，仅端点不同）
GRSAI_DRAW_API_URL=https://grsai.dakka.com.cn/v1/draw/completions

# ===== 阿里云 OSS（可选，grsai 参考图本地上传）=====
# 用于：grsai 生图时上传本地参考图，获取公开 URL 后传入 urls[] 参数
# 如未配置，--reference 本地文件参数将被忽略，仅执行文生图
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# OSS_BUCKET=your-bucket

# ===== 输出参数 =====
# VF_PROVIDER   — 引擎优先级：auto（默认，云雾优先→grsai备用）/ yunwu / grsai
# VF_IMAGE_SIZE — 默认分辨率：1K / 2K / 4K
# VF_OUTPUT_FMT — 输出格式：jpg / png / webp
# VF_JPG_QUALITY— JPEG 质量：1-95
VF_PROVIDER=auto
VF_IMAGE_SIZE=2K
VF_OUTPUT_FMT=jpg
VF_JPG_QUALITY=85

# ===== 超时设置 =====
# LLM_TIMEOUT — API 请求超时时间（秒）
LLM_TIMEOUT=120
